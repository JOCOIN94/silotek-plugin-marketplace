{
  "mcpServers": {
    "serial-mcp": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/stek747/serial-mcp-server@v1.19.9",
        "serial-mcp"
      ],
      "env": {
        "PYTHONUTF8": "1",
        "PYTHONIOENCODING": "utf-8",
        "SERIAL_CHAR_DELAY": "100",
        "SERIAL_WRITE_CONFIRM": "r3"
      }
    }
  }
}
