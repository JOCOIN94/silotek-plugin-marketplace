{
  "name": "serial-mcp",
  "description": "AI가 임베디드 보드(ESP32/STM32 등)의 시리얼 로그를 직접 읽는 헤드리스 MCP 서버 + 블랙박스 디버깅 안내 스킬. USB 시리얼 자동 인식·다중 포트·웹 뷰어 내장.",
  "version": "0.1.2",
  "author": {
    "name": "Silotek"
  },
  "license": "UNLICENSED",
  "keywords": [
    "serial",
    "mcp",
    "esp32",
    "stm32",
    "firmware",
    "silotek"
  ],
  "mcpServers": {
    "serial-mcp": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/JOCOIN94/silotek-serial-mcp",
        "serial-mcp"
      ],
      "env": {
        "SERIAL_PORT": "${SERIAL_PORT:-}",
        "SERIAL_NAMES": "${SERIAL_NAMES:-}",
        "SERIAL_AUTONAME": "${SERIAL_AUTONAME:-}",
        "SERIAL_BAUD": "${SERIAL_BAUD:-}",
        "SERIAL_TEE": "${SERIAL_TEE:-}",
        "SERIAL_EXCLUDE": "${SERIAL_EXCLUDE:-}",
        "SERIAL_INCLUDE": "${SERIAL_INCLUDE:-}",
        "SERIAL_BUFFER_LINES": "${SERIAL_BUFFER_LINES:-}",
        "SERIAL_DEDUP": "${SERIAL_DEDUP:-}",
        "SERIAL_WEB": "${SERIAL_WEB:-}",
        "SERIAL_HOTPLUG": "${SERIAL_HOTPLUG:-}"
      }
    }
  }
}
